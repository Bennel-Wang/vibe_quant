# 量化交易系统 .gitignore

# ─── 敏感配置（含 API Token，绝对不提交）───
config.yaml
*.env
.env.*

# ─── Python ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# ─── 虚拟环境 ─────────────────────────────
venv/
.venv/
env/
ENV/

# ─── 数据文件（体积大，不入版本控制）──────
data/
logs/
*.log

# ─── IDE ─────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Jupyter ──────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── 测试覆盖率 ───────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/
